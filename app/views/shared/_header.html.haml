%header
  %nav.navbar.navbar-default
    .container-fluid
      .navbar-header
        = link_to 'MyApp', root_path, class: 'navbar-brand'
      %ul.nav.navbar-nav
        %li= link_to 'Темы', themes_path
        %li= link_to 'Изображения', images_path
        %li= link_to 'Оценки', values_path
        %li= link_to 'Пользователи', users_path
        %li= link_to 'Ruby on Rails Website', 'http://rubyonrails.org'
      %ul.nav.navbar-nav.pull-right
        - if signed_in?
          %li.logged
            = current_user.email
          %li
            = gravatar_for current_user, size: 30
          %li.dropdown
            %a.dropdown-toggle{ href: "#", "data-toggle": "dropdown" }
              Account
              %b.caret
            %ul.dropdown-menu
              %li= link_to "Profile", current_user
              %li.divider
              %li= link_to "Sign out", signout_path, method: :delete
        - else
          %li= link_to "Sign in", signin_path
          %li= link_to "Sign up", signup_path