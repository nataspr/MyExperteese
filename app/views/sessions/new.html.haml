%h1 Sign in

= form_for(:session, url: signin_path) do |f|
  .field
    = f.label :email
    = f.email_field :email, class: 'form-control'
  .field
    = f.label :password
    = f.password_field :password, class: 'form-control'
  .actions
    = f.submit "Sign in", class: "btn btn-primary"

%p New user? #{link_to "Sign up now!", signup_path}
