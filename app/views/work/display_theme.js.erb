// Получаем данные из контроллера
var imageData = '<%= raw @image_data %>';
console.log("IN display_theme: @image_data = " + imageData);
var valuesQty = '<%= @image_data[:values_qty] %>';
console.log("IN display_theme: valuesQty = " + valuesQty);
$('.left_controls span.total_values h2.total').append().html(valuesQty);

// Отображаем тему
var selectedTheme = '<%= @image_data[:theme] %>';
if(selectedTheme == "Выберите тему для оценки"|| selectedTheme == ""){
  $('.img-left-side').css({"display": "none"});
  $('.img-right-side').css({"display": "none"});
  $('.image .image_display .image_diag').css({"display": "none"});
} else {
  $('.img-left-side').css({"display": "block"});
  $('.img-right-side').css({"display": "block"});
  $('.image .image_display .image_diag').css({"display": "block"});
}
$('.image_display h2.up-theme').append().html(selectedTheme);

// Восстанавливаем кнопку выбора темы
$('.select_theme').empty().html("<%= j render 'work/button_theme_select' %>");

// Данные об изображении из @image_data
var oneImageName = '<%= @image_data[:name] %>';
var oneImageFile = '<%= @image_data[:file] %>';
var oneImageId = '<%= @image_data[:image_id] %>';
var themeImagesSize = '<%= @image_data[:images_arr_size] %>';
var selectedThemeId = '<%= @image_data[:theme_id] %>';
var pathImage = '<%= @image_data[:image_url] %>';   // ← готовый URL

console.log("IN display_theme: oneImageFile = " + oneImageFile);
console.log("IN display_theme: oneImageId = " + oneImageId);
console.log("IN display_theme: pathImage = " + pathImage);

// Отображаем название изображения
$('.image_display h2.up').append().html(oneImageName);

// Отображаем изображение
$(".img-center").html('<img alt="Selected Image" src="' + pathImage + '" style="width:100%; height:auto;" title="Selected image"/>');

// РАБОТА №6 ПЕРЕЛИСТЫВАНИЕ ИЗОБРАЖЕНИЙ ПО ТЕМАМ
// Сохранить текущий индекс и параметры темы в data-атрибуты
$('.image_display').data('current-index', <%= @image_data[:index] %>);
$('.image_display').data('theme-id', <%= @image_data[:theme_id] %>);
$('.image_display').data('images-count', <%= @image_data[:images_arr_size] %>);

// Функция обновления интерфейса после ответа API
function updateImageDisplay(data) {
  $('.image_display h2.up').html(data.name);
  $(".img-center").html('<img alt="Selected Image" src="' + data.image_url + '" style="width:100%; height:auto;" title="Selected image"/>');
  $('.image_display').data('current-index', data.new_image_index);
  $('.image_display').data('current-image-id', data.image_id);
  // При необходимости обновление средней оценки
  if (data.common_ave_value) {
    $('.common_ave_value').html(data.common_ave_value);
  }
}

// Обработчик кнопки "Вправо"
$('.img-right-side').off('click').on('click', function() {
  var currentIndex = $('.image_display').data('current-index');
  var themeId = $('.image_display').data('theme-id');
  var imagesCount = $('.image_display').data('images-count');

  $.ajax({
    type: "GET",
    url: "/api/next_image",
    data: { index: currentIndex, theme_id: themeId, length: imagesCount },
    dataType: 'json'
  }).done(function(data) {
    console.log(data.notice);
    updateImageDisplay(data);
  }).fail(function(xhr) {
    console.log("Ошибка: " + xhr.responseText);
  });
});

// Обработчик кнопки "Влево"
$('.img-left-side').off('click').on('click', function() {
  var currentIndex = $('.image_display').data('current-index');
  var themeId = $('.image_display').data('theme-id');
  var imagesCount = $('.image_display').data('images-count');

  $.ajax({
    type: "GET",
    url: "/api/prev_image",
    data: { index: currentIndex, theme_id: themeId, length: imagesCount },
    dataType: 'json'
  }).done(function(data) {
    console.log(data.notice);
    updateImageDisplay(data);
  }).fail(function(xhr) {
    console.log("Ошибка: " + xhr.responseText);
  });
});